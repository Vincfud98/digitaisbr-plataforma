rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read/write their own profile
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Authenticated users can read all collections
    match /{collection}/{document=**} {
      allow read: if request.auth != null;
    }

    // Admin write access (check custom claim or specific UIDs)
    match /plans/{doc} {
      allow write: if request.auth != null;
    }
    match /products/{doc} {
      allow write: if request.auth != null;
    }
    match /categories/{doc} {
      allow write: if request.auth != null;
    }
    match /stores/{doc} {
      allow write: if request.auth != null;
    }
    match /associados/{doc} {
      allow write: if request.auth != null;
    }
    match /sales/{doc} {
      allow write: if request.auth != null;
    }
    match /commissions/{doc} {
      allow write: if request.auth != null;
    }
    match /financial/{doc} {
      allow write: if request.auth != null;
    }
    match /benefits/{doc} {
      allow write: if request.auth != null;
    }
    match /partners/{doc} {
      allow write: if request.auth != null;
    }
    match /contents/{doc} {
      allow write: if request.auth != null;
    }
    match /notifications/{doc} {
      allow write: if request.auth != null;
    }
    match /services/{doc} {
      allow write: if request.auth != null;
    }
    match /highlights/{doc} {
      allow write: if request.auth != null;
    }
    match /tickets/{doc} {
      allow write: if request.auth != null;
    }
    match /reports/{doc} {
      allow write: if request.auth != null;
    }
    match /forumTopics/{doc} {
      allow write: if request.auth != null;
    }
    match /_meta/{doc} {
      allow read, write: if request.auth != null;
    }
  }
}
