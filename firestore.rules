rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Users — each user can read/write their own profile, admins can read all
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isOwner(userId) && request.resource.data.role == 'associado';
      allow update: if (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])) || isAdmin();
      allow delete: if isAdmin();
    }

    // Admin-managed collections — admin full access, associados read-only
    match /plans/{doc} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /products/{doc} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /categories/{doc} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /benefits/{doc} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /partners/{doc} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /highlights/{doc} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /reports/{doc} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    match /financial/{doc} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Associados — admin full access, associado can read own
    match /associados/{doc} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Stores — admin full access, associado can update own store
    match /stores/{doc} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAdmin() || (isAuth() && resource.data.associadoId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Sales — checkout creates, must include required fields
    match /sales/{doc} {
      allow read: if isAuth();
      allow create: if true
        && request.resource.data.keys().hasAll(['productId', 'customerName', 'customerEmail', 'totalPrice', 'status'])
        && request.resource.data.status == 'pendente';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Orders — checkout creates, must include required fields
    match /orders/{doc} {
      allow read: if isAuth();
      allow create: if true
        && request.resource.data.keys().hasAll(['storeSlug', 'items', 'total', 'status', 'customer'])
        && request.resource.data.status == 'aguardando_pagamento';
      allow update: if isAdmin();
    }

    // Commissions — admin full access, associado read own
    match /commissions/{doc} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Contents — admin manages, all authenticated read
    match /contents/{doc} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Forum — authenticated can read/create, admin can manage
    match /forumTopics/{doc} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    // Notifications — admin creates, user reads own
    match /notifications/{doc} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // Services — associado creates requests, admin manages
    match /services/{doc} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    // Support tickets — associado creates, owner and admin can update
    match /tickets/{doc} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }
    match /ticketMessages/{doc} {
      allow read: if isAuth();
      allow create: if isAuth();
    }

    // Metadata
    match /_meta/{doc} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
  }
}
